{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spotlight-rules.com/schema/plans.schema.json",
  "title": "API Plans",
  "description": "API Evangelist Plans artifact — the access tiers/plans offered for an API.",
  "type": "object",
  "required": [
    "name",
    "plans"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "currency": {
      "type": "string",
      "description": "ISO 4217 currency code (e.g. USD)."
    },
    "plans": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "price": {
            "type": [
              "number",
              "string"
            ]
          },
          "features": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "limits": {
            "type": "array"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
